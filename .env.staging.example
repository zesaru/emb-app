# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_staging_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_staging_supabase_service_role_key_here
DATABASE_URL=postgresql://postgres:your_db_password@db.your-staging-project.supabase.co:5432/postgres

# Application Configuration
NEXT_PUBLIC_APP_URL=https://your-staging-app.example.com
BASE_URL=https://your-staging-app.example.com

# Email Service
# Keep delivery disabled in staging unless explicitly validating real outbound email.
RESEND_API_KEY=your_resend_api_key_here
EMBPERUJAPAN_EMAIL=sistema@embperujapan.org
EMAIL_DELIVERY_ENABLED=false
EMAIL_TEST_MODE=false
EMAIL_TEST_USER=

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7
BACKUP_LOCAL_PATH=./backups
BACKUP_STORAGE_BUCKET=backups
CRON_SECRET=your_random_secret_here

# Vercel Configuration (only if used by CI/CD automation)
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id

# E2E Test Configuration (optional for staging automation)
E2E_ADMIN_EMAIL=test-admin@example.com
E2E_ADMIN_PASSWORD=test-password-123
E2E_USER_EMAIL=test-user@example.com
E2E_USER_PASSWORD=test-password-123

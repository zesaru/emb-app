{
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "env:dev": "powershell -Command \"Copy-Item .env.dev.local .env.local -Force\"",
    "env:staging": "powershell -Command \"Copy-Item .env.staging.local .env.local -Force\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "gen-types": "supabase gen types typescript --linked > types/database.type.ts",
    "backup:setup": "mkdir -p backups",
    "backup:full": "tsx scripts/backup-full.ts",
    "backup:restore-full": "tsx scripts/restore-full.ts",
    "backup:to-sql": "tsx scripts/backup-to-sql.ts",
    "backup:restore-local": "tsx scripts/restore-to-local.ts",
    "vacation:backfill:japan": "tsx scripts/backfill-japan-vacation-grants.ts",
    "dev:all": "pnpm run supabase:start && pnpm run dev",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:reset": "npx supabase db reset",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm run test && pnpm run test:e2e"
  },
